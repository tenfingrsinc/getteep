# Runtime
# Keep this as development for local simulator/dev runs. The simulator refuses NODE_ENV=production.
NODE_ENV=development

# Teep backend (settlement + balance layer)
TEEP_BACKEND_URL=http://localhost:3001

# Shared secret between x-agent and backend.
# This is NOT from X. Generate a random secret and set the same value in backend/.env.
X_AGENT_TOKEN=

# X bot account
# Numeric X user id for the bot account, e.g. the account behind @teep_app.
X_BOT_USER_ID=
X_BOT_USERNAME=teep_app

# X API app-only bearer token. Used to read mentions and referenced tweet context.
X_BEARER_TOKEN=

# OAuth 2.0 user access token for the bot account. Required to post replies.
# The token must have tweet.write access. If your X access token expires, rotate it here.
X_BOT_ACCESS_TOKEN=

# Listener
# Polling is the beta/default path. X_MENTIONS_PAGE_SIZE is clamped to X API limits in code.
X_POLL_INTERVAL_MS=45000
X_MENTIONS_PAGE_SIZE=20

# Local simulator defaults. These are dev-only and do not touch X.
X_SIM_AUTHOR_ID=100000001
X_SIM_AUTHOR_USERNAME=teep_tester
X_SIM_PARENT_AUTHOR_ID=100000002
X_SIM_PARENT_AUTHOR_USERNAME=sample_creator

# Optional: filtered stream. Leave false for beta unless stream rules are implemented for your X API tier.
X_USE_FILTERED_STREAM=false
